# Copy this file to .env and fill in real values. Never commit .env.
# Full setup steps: see README.md "Local development" and "Deployment" sections.

# --- Supabase (Postgres + Auth + Storage) -----------------------------------
# Create a project at https://supabase.com/dashboard, then:
#  - Project Settings -> Database -> Connection string -> "Transaction" pooler (port 6543)
#    for DATABASE_URL, and "Session"/direct (port 5432) for DIRECT_URL.
#  - Project Settings -> API for the URL + anon key.
#  - Project Settings -> API -> service_role key for SUPABASE_SERVICE_ROLE_KEY
#    (SERVER-ONLY — never expose this to the browser, never prefix with NEXT_PUBLIC_).
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key]"
SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"

# --- Email (Resend) ----------------------------------------------------------
# Create an API key at https://resend.com/api-keys. Optional — if unset, the app
# starts normally but email sending is disabled (visible in Admin > Settings).
RESEND_API_KEY=""
EMAIL_FROM="Rabea.art <orders@yourdomain.com>"

# --- App-level ----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Random long secret; required to call POST /api/cron/cleanup-uploads.
CRON_SECRET="generate-a-random-secret-value"

# --- Pre-launch gate ----------------------------------------------------------
# In production every URL shows the /coming-soon page by DEFAULT (no env needed).
# Launch day: set COMING_SOON=0 to open the site. Optional team preview before launch:
# set PREVIEW_KEY to a long random string, then visit https://rabea.art/?preview=<key>
# once — a 30-day cookie keeps the bypass. Local development is never gated.
# COMING_SOON="0"
# PREVIEW_KEY=""
