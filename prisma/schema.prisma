// Rabea.art data model.
// Connection URLs are NOT declared here (Prisma 7) — see prisma.config.ts (CLI/migrations)
// and src/lib/prisma.ts (runtime, via a pg driver adapter).
//
// ⚠️  NEVER RUN `prisma db push` AGAINST THIS DATABASE.  ⚠️
//
// Two objects exist in the database that this file cannot express, because Prisma models
// neither sequences nor CHECK constraints:
//
//   1. SEQUENCE "order_ref_seq"  — order submission calls nextval() on it inside the
//      transaction (src/lib/orders/submit.ts). Without it, EVERY ORDER FAILS.
//   2. CHECK "product_variants_stock_non_negative" — the last-resort guard against
//      negative stock.
//
// Both are created in prisma/migrations/0_init/migration.sql. `prisma db push` reconciles the
// database to THIS file and will happily drop anything it cannot see — producing a database
// that looks correct, passes every schema diff, and cannot take an order. Prisma will not warn
// you, because from its point of view nothing is missing.
//
// Use `prisma migrate deploy`, or paste the migration SQL directly (which is how this project
// actually applies schema changes — see docs/SETUP-DATABASE.md). After any restore or rebuild,
// run docs/verify-restore.sql: checks 2 and 4 exist specifically to catch this.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrderStatus {
  NEW
  REVIEW
  NEEDS_INFO
  QUOTED
  ACCEPTED
  DECLINED
  PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  NOT_REQUIRED
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum AdminRole {
  OWNER
  ADMIN
  STAFF
}

enum ProductType {
  SHIRT
  PAINTING
}

enum ItemKind {
  SHIRT
  PAINTING
  CUSTOM_SHIRT
  CUSTOM_PAINTING
  CUSTOM_OTHER
}

enum ContactMethod {
  PHONE
  WHATSAPP
  EMAIL
  INTERNAL // CommunicationLog only — never a customer's preferred contact (app-validated)
}

enum SizeScope {
  SHIRT
  PAINTING
}

// ---------------------------------------------------------------------------
// Admin / RBAC
// ---------------------------------------------------------------------------

model AdminUser {
  id          String    @id // = Supabase auth.users.id
  email       String    @unique
  name        String
  role        AdminRole @default(STAFF)
  active      Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  statusHistoryEntries OrderStatusHistory[]
  communicationLogs    CommunicationLog[]
  auditLogs            AuditLog[]

  @@map("admin_users")
}

// ---------------------------------------------------------------------------
// Customers
// ---------------------------------------------------------------------------

model Customer {
  id               String         @id @default(cuid())
  name             String
  phone            String?
  phoneNormalized  String?        @db.VarChar(32)
  whatsapp         String?
  email            String?
  emailNormalized  String?
  country          String?
  city             String?
  street           String?
  building         String?
  apt              String?
  postal           String?
  instructions     String?
  preferredContact ContactMethod?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  orders Order[]

  @@index([phoneNormalized])
  @@index([emailNormalized])
  @@map("customers")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id        String      @id @default(cuid())
  type      ProductType
  code      String      @unique
  nameAr    String
  nameEn    String
  sortOrder Int         @default(0)
  active    Boolean     @default(true)

  products Product[]

  @@map("categories")
}

model Product {
  id                  String      @id @default(cuid())
  slug                String      @unique
  type                ProductType
  categoryId          String
  nameAr              String
  nameEn              String
  descAr              String?
  descEn              String?
  price               Decimal?    @db.Decimal(10, 2) // shirts base price; null for paintings
  sale                Decimal?    @db.Decimal(10, 2)
  featured            Boolean     @default(false)
  archived            Boolean     @default(false)
  trackStock          Boolean     @default(false) // shirts only, opt-in
  printAvailable      Boolean     @default(false)
  embroideryAvailable Boolean     @default(false)
  isOriginal          Boolean     @default(false) // paintings: one-of-a-kind
  artistNoteAr        String?
  artistNoteEn        String?
  prepAr              String?
  prepEn              String?
  displayOrder        Int         @default(0)
  seoTitle            String?
  seoDescription      String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  archivedAt          DateTime?

  category   Category         @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  colors     ProductColor[]
  sizes      ProductSize[]
  variants   ProductVariant[]
  orderItems OrderItem[]

  @@index([type, archived])
  @@index([categoryId])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  path      String // object key in the public "product-images" bucket
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  // Product-image orphan cleanup matches stored objects against this column.
  @@index([path])
  @@map("product_images")
}

model Color {
  id        String  @id @default(cuid())
  code      String  @unique
  nameAr    String
  nameEn    String
  hex       String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  variants ProductVariant[]
  products ProductColor[]

  @@map("colors")
}

model ProductColor {
  productId String
  colorId   String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color   Color   @relation(fields: [colorId], references: [id])

  @@id([productId, colorId])
  // colorId is only the trailing column of the @@id composite, so it cannot serve a lookup
  // filtered on colorId alone (leftmost-prefix rule) — e.g. checking whether a Color is in use
  // before deleting it. (DB-03: the FK-index sweep missed the join-table FKs.)
  @@index([colorId])
  @@map("product_colors")
}

model Size {
  id        String    @id @default(cuid())
  scope     SizeScope
  code      String // "XS".."XXL" or "A5"/"A4"/"A3"/"custom"
  labelAr   String
  labelEn   String
  sortOrder Int       @default(0)
  active    Boolean   @default(true)

  variants     ProductVariant[]
  productSizes ProductSize[]

  @@unique([scope, code])
  @@map("sizes")
}

model ProductSize {
  // painting size -> price
  id        String  @id @default(cuid())
  productId String
  sizeId    String
  price     Decimal @db.Decimal(10, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size    Size    @relation(fields: [sizeId], references: [id])

  @@unique([productId, sizeId])
  // sizeId is the trailing column of the @@unique, so `sizeInUse()` (options/actions.ts) —
  // `productSize.count({ where: { sizeId } })` before deleting a Size — was a seq scan. (DB-03)
  @@index([sizeId])
  @@map("product_sizes")
}

model ProductVariant {
  // shirt color x size -> stock (auto-generated from the product's selected color/size sets)
  id        String  @id @default(cuid())
  productId String
  colorId   String?
  sizeId    String?
  sku       String? @unique
  stock     Int     @default(0)
  active    Boolean @default(true)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  color      Color?      @relation(fields: [colorId], references: [id])
  size       Size?       @relation(fields: [sizeId], references: [id])
  orderItems OrderItem[]

  @@unique([productId, colorId, sizeId])
  // colorId/sizeId are non-leading columns of the @@unique, so neither serves a single-column
  // lookup — `sizeInUse()` (options/actions.ts) filters `productVariant.count({ where: { sizeId } })`
  // alone, and the color equivalent. (DB-03)
  @@index([colorId])
  @@index([sizeId])
  @@map("product_variants")
}

model Frame {
  id      String  @id @default(cuid())
  code    String  @unique
  labelAr String
  labelEn String
  add     Decimal @db.Decimal(10, 2) @default(0)
  active  Boolean @default(true)
  sortOrder Int   @default(0)

  @@map("frames")
}

model Material {
  id        String  @id @default(cuid())
  code      String  @unique
  labelAr   String
  labelEn   String
  active    Boolean @default(true)
  sortOrder Int     @default(0)

  @@map("materials")
}

model ProductionMethod {
  // scope: "shirt" | "custom-painting-style" | "placement" | "orientation" | "shirt-type"
  id        String  @id @default(cuid())
  scope     String
  code      String
  labelAr   String
  labelEn   String
  active    Boolean @default(true)
  sortOrder Int     @default(0)

  @@unique([scope, code])
  @@map("production_methods")
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

model Order {
  id                    String        @id @default(cuid())
  ref                   String        @unique // "RA-1042"
  status                OrderStatus   @default(NEW)
  pay                   PaymentStatus @default(NOT_REQUIRED)
  estTotal              Decimal?      @db.Decimal(10, 2)
  finalPrice            Decimal?      @db.Decimal(10, 2)
  eta                   DateTime?
  customerId            String
  contactMethod         ContactMethod
  notes                 String?
  consentTerms          Boolean       @default(false)
  consentCustomApproval Boolean       @default(false)
  archived              Boolean       @default(false)
  idempotencyKey        String        @unique
  locale                String        @default("ar")
  stockAppliedAt        DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  customer       Customer             @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  files          OrderFile[]
  history        OrderStatusHistory[]
  communications CommunicationLog[]

  // Postgres does not auto-index foreign keys, and Prisma only creates what it is told — so
  // every FK in this schema was unindexed until now. customerId drives the customers list and
  // the customers CSV export (both group orders by customer).
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  // Almost every admin figure filters `archived: false` AND ranges on createdAt/status. The
  // single-column indexes above stay: they still serve the unfiltered NEW-order sidebar count
  // and plain createdAt sorts, which cannot use a composite led by `archived`.
  @@index([archived, createdAt])
  @@index([archived, status])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  kind           ItemKind
  productId      String?
  variantId      String?
  labelAr        String?
  labelEn        String?
  qty            Int      @default(1)
  unitPrice      Decimal? @db.Decimal(10, 2) // null = manual pricing
  finalUnitPrice Decimal? @db.Decimal(10, 2) // admin override
  optionsJson    Json
  notes          String?
  snapshotNameAr String?
  snapshotNameEn String?
  stockWarning   Boolean  @default(false)
  createdAt      DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  files   OrderFile[]

  @@index([orderId])
  // `items: { some: { kind: { in: [...] } } }` on the overview and reports pages compiles to a
  // correlated subquery over this table.
  @@index([kind])
  // productId/variantId FKs were unindexed — needed once product usage is queried from order
  // history and to keep the FK joins off seq scans as orders accumulate. (DB-03)
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model OrderFile {
  id           String   @id @default(cuid())
  orderId      String
  orderItemId  String?
  bucketPath   String // order-uploads/{orderId}/{uuid}-name
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([orderItemId])
  // The nightly orphan-cleanup cron looks up one bucketPath per storage object it scans
  // (api/cron/cleanup-uploads). Unindexed, that was a sequential scan per object, repeated for
  // every retained file on every run — cost growing with total files kept, not with orphans.
  @@index([bucketPath])
  // Admin files grid sorts by newest with skip/take.
  @@index([createdAt])
  @@map("order_files")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  byAdminId String?
  at        DateTime    @default(now())

  order   Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  byAdmin AdminUser? @relation(fields: [byAdminId], references: [id])

  @@index([orderId])
  @@index([byAdminId])
  @@map("order_status_history")
}

model CommunicationLog {
  id        String        @id @default(cuid())
  orderId   String
  channel   ContactMethod
  text      String
  byAdminId String
  at        DateTime      @default(now())

  order   Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  byAdmin AdminUser @relation(fields: [byAdminId], references: [id])

  @@index([orderId])
  @@index([byAdminId])
  @@map("communication_logs")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String // "order.status.update", "product.delete", "user.role.change", "csv.export"
  targetType String
  targetId   String?
  metadata   Json?
  at         DateTime @default(now())

  actor AdminUser @relation(fields: [actorId], references: [id])

  @@index([actorId])
  // Audit review is always "what happened recently", newest first.
  @@index([at])
  @@map("audit_logs")
}

model EmailLog {
  id                String   @id @default(cuid())
  orderId           String?
  to                String
  template          String
  status            String // "sent" | "failed"
  providerMessageId String?
  error             String?
  at                DateTime @default(now())

  // This table had no index at all and grows one row per outbound email forever. Reports
  // groupBy(status) over an `at` range, and lists the most recent failures.
  @@index([at])
  @@index([status, at])
  @@index([orderId])
  @@map("email_logs")
}

model RateLimitBucket {
  // Postgres-backed sliding-window rate limiter (avoids a Redis/Upstash vendor dependency).
  key        String   @id // e.g. "login:203.0.113.4" or "order-submit:203.0.113.4"
  count      Int      @default(1)
  windowFrom DateTime @default(now())

  @@map("rate_limit_buckets")
}

model Settings {
  id                 Int      @id @default(1)
  whatsapp           String
  email              String
  instagram          String?
  announcementAr     String?
  announcementEn     String?
  announcementActive Boolean  @default(false)
  customOtherEnabled Boolean  @default(true)
  updatedAt          DateTime @updatedAt

  @@map("settings")
}
